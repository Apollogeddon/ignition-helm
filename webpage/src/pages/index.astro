---
import logoImage from "../assets/favicon.png";
import ArchitectureComparison from "../components/ArchitectureComparison.astro";
import FeatureGrid from "../components/FeatureGrid.astro";
import Hero from "../components/Hero.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Ignition Helm Charts" description="Enterprise-grade Helm charts for deploying Inductive Automation Ignition on Kubernetes.">
  <Hero 
    tagline="The definitive way to deploy scalable, resilient Ignition architectures on Kubernetes."
    logo={logoImage}
  />
  
  <FeatureGrid />
  
  <ArchitectureComparison />
  
  <footer class="custom-footer">
    <div class="footer-content">
      <p>Released under the MIT License.</p>
      <p>Built with Astro.</p>
    </div>
  </footer>
</BaseLayout>
