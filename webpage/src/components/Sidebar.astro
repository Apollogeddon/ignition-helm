---
import { getCollection } from "astro:content";

const docs = await getCollection("docs");
const base = import.meta.env.BASE_URL;

// Simple organization logic based on directory structure
const guides = docs
	.filter((d) => d.id.startsWith("guides/"))
	.sort((a, b) => a.data.title.localeCompare(b.data.title));
const charts = docs
	.filter((d) => d.id.startsWith("charts/"))
	.sort((a, b) => a.data.title.localeCompare(b.data.title));

const sections = [
	{ label: "Guides", items: guides },
	{ label: "Charts", items: charts },
];
---

<nav class="sidebar">
  {sections.map(section => (
    <div class="section">
      <h4 class="section-title">{section.label}</h4>
      <ul class="section-items">
        {section.items.map(item => (
          <li>
            <a href={`${base}/docs/${item.id}/`} class="sidebar-link">
              {item.data.title}
            </a>
          </li>
        ))}
      </ul>
    </div>
  ))}
</nav>

<style>
  .sidebar {
    padding-right: 1rem;
  }

  .section {
    margin-bottom: 2rem;
  }

  .section-title {
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--sl-color-text-muted);
    margin-bottom: 1rem;
    padding-left: 1rem;
  }

  .section-items {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .sidebar-link {
    display: block;
    padding: 0.5rem 1rem;
    font-size: 0.95rem;
    text-decoration: none;
    color: var(--sl-color-text-muted);
    border-radius: 6px;
    transition: all 0.2s;
  }

  .sidebar-link:hover {
    color: var(--sl-color-accent);
    background: var(--sl-color-accent-low);
  }

  /* We could use client-side logic or active class here if needed */
</style>
